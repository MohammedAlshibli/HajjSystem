@model HajjSystem.Web.Models.LoginModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>نظام إدارة الحج — تسجيل الدخول</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a1628;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Animated background */
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(26,82,118,0.4) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(21,143,79,0.2) 0%, transparent 50%),
                radial-gradient(ellipse at 60% 80%, rgba(125,60,152,0.15) 0%, transparent 50%);
            animation: bgPulse 8s ease-in-out infinite alternate;
        }

        @@keyframes bgPulse {
            0%   { opacity: 0.7; }
            100% { opacity: 1; }
        }

        /* Floating orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.15;
            animation: float 12s ease-in-out infinite;
        }
        .orb-1 { width: 400px; height: 400px; background: #1a5276; top: -100px; left: -100px; animation-delay: 0s; }
        .orb-2 { width: 300px; height: 300px; background: #148f55; bottom: -80px; right: -80px; animation-delay: 3s; }
        .orb-3 { width: 200px; height: 200px; background: #7d3c98; top: 40%; left: 60%; animation-delay: 6s; }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50%       { transform: translate(30px, -30px) scale(1.05); }
        }

        /* Card */
        .login-wrapper {
            position: relative;
            z-index: 10;
            display: flex;
            width: 900px;
            max-width: 95vw;
            min-height: 520px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.05);
        }

        /* Left panel */
        .login-banner {
            flex: 1;
            background: linear-gradient(145deg, #1a3a5c 0%, #0d6e4a 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 40px;
            position: relative;
            overflow: hidden;
        }

        .login-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .banner-icon {
            font-size: 72px;
            margin-bottom: 20px;
            filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3));
            animation: iconGlow 3s ease-in-out infinite alternate;
        }

        @@keyframes iconGlow {
            0%   { filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3)); }
            100% { filter: drop-shadow(0 4px 30px rgba(255,215,0,0.4)); }
        }

        .banner-title {
            color: white;
            font-size: 1.7rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 12px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
        }

        .banner-subtitle {
            color: rgba(255,255,255,0.65);
            font-size: 0.9rem;
            text-align: center;
            line-height: 1.7;
        }

        .banner-divider {
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, transparent, rgba(255,215,0,0.6), transparent);
            margin: 20px auto;
            border-radius: 2px;
        }

        .banner-badge {
            margin-top: 32px;
            padding: 8px 20px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            color: rgba(255,255,255,0.7);
            font-size: 0.78rem;
            backdrop-filter: blur(4px);
        }

        /* Right panel — form */
        .login-form-panel {
            width: 380px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 40px;
        }

        .form-heading {
            margin-bottom: 32px;
        }

        .form-heading h3 {
            color: #0a1628;
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .form-heading p {
            color: #8a9bb0;
            font-size: 0.85rem;
        }

        .field-group {
            margin-bottom: 20px;
        }

        .field-group label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: #3d5068;
            margin-bottom: 7px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .field-group .input-wrap {
            position: relative;
        }

        .field-group .input-icon {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aab8c5;
            font-size: 1rem;
            pointer-events: none;
        }

        .field-group input {
            width: 100%;
            padding: 12px 42px 12px 16px;
            border: 1.5px solid #dce3eb;
            border-radius: 10px;
            font-size: 0.95rem;
            color: #0a1628;
            background: #f8fafc;
            transition: all 0.2s;
            outline: none;
            text-align: right;
        }

        .field-group input:focus {
            border-color: #1a5276;
            background: white;
            box-shadow: 0 0 0 4px rgba(26,82,118,0.08);
        }

        .field-group input::placeholder { color: #b5c0cc; }

        .error-box {
            background: #fff5f5;
            border: 1px solid #fcc;
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            color: #c0392b;
            font-size: 0.85rem;
        }

        .btn-submit {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #1a5276, #2e86c1);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 4px 15px rgba(26,82,118,0.3);
            margin-top: 8px;
            position: relative;
            overflow: hidden;
        }

        .btn-submit::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
            opacity: 0;
            transition: opacity 0.2s;
        }

        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(26,82,118,0.4);
        }

        .btn-submit:hover::after { opacity: 1; }
        .btn-submit:active { transform: translateY(0); }

        .form-footer {
            margin-top: 28px;
            text-align: center;
            color: #aab8c5;
            font-size: 0.75rem;
        }

        @@media (max-width: 700px) {
            .login-banner { display: none; }
            .login-wrapper { width: 95vw; }
            .login-form-panel { width: 100%; padding: 36px 28px; }
        }
    </style>
</head>
<body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="login-wrapper">

        <!-- Left banner -->
        <div class="login-banner">
            <div class="banner-icon">🕌</div>
            <div class="banner-title">نظام إدارة الحج</div>
            <div class="banner-divider"></div>
            <div class="banner-subtitle">
                منظومة متكاملة لإدارة<br />
                تسجيل وتوزيع الحجاج<br />
                والرحلات الميدانية
            </div>
            <div class="banner-badge">✦ نظام آمن ومشفّر ✦</div>
        </div>

        <!-- Right form -->
        <div class="login-form-panel">
            <div class="form-heading">
                <h3>مرحباً بك</h3>
                <p>سجّل دخولك للمتابعة</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-box">
                    @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

                <div class="field-group">
                    <label>اسم المستخدم</label>
                    <div class="input-wrap">
                        <span class="input-icon">👤</span>
                        <input asp-for="UserName" placeholder="أدخل اسم المستخدم" autofocus />
                    </div>
                </div>

                <div class="field-group">
                    <label>كلمة المرور</label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        <input asp-for="Password" type="password" placeholder="أدخل كلمة المرور" />
                    </div>
                </div>

                <button type="submit" class="btn-submit">دخول ←</button>
            </form>

            <div class="form-footer">
                جميع الحقوق محفوظة &copy; @DateTime.Now.Year — نظام الحج
            </div>
        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
