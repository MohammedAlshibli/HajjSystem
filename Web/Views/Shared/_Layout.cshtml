<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@ViewData["Title"] вҖ” ЩҶШёШ§Щ… Ш§Щ„ШӯШ¬</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css"/>
    <style>
        body { background:#f0f4f8; font-family:'Segoe UI',Tahoma,sans-serif; }
        .topbar {
            background: linear-gradient(135deg,#1a3a5c,#0d6e4a);
            color:white; padding:12px 24px;
            display:flex; justify-content:space-between; align-items:center;
            box-shadow:0 2px 10px rgba(0,0,0,.25); position:sticky; top:0; z-index:1000;
        }
        .topbar .brand { font-size:1.1rem; font-weight:700; text-decoration:none; color:white; }
        .sidebar {
            width:220px; min-height:calc(100vh - 52px);
            background:white; border-left:1px solid #e2e8f0;
            padding:16px 0; position:fixed; top:52px; right:0; overflow-y:auto;
        }
        .sidebar a {
            display:flex; align-items:center; gap:10px;
            padding:10px 20px; color:#374151; text-decoration:none;
            font-size:.9rem; border-right:3px solid transparent;
            transition:all .15s;
        }
        .sidebar a:hover, .sidebar a.active {
            background:#f0f9ff; color:#1a5276;
            border-right-color:#1a5276;
        }
        .sidebar .section-title {
            font-size:.7rem; font-weight:700; color:#9ca3af;
            padding:12px 20px 4px; text-transform:uppercase; letter-spacing:.5px;
        }
        .main-content { margin-right:220px; padding:24px; }
        .page-card {
            background:white; border-radius:12px; padding:24px;
            box-shadow:0 2px 12px rgba(0,0,0,.07);
        }
        .page-title { font-size:1.2rem; font-weight:700; color:#1a3a5c; margin-bottom:20px; }
        .stat-card {
            background:white; border-radius:10px; padding:18px;
            box-shadow:0 2px 8px rgba(0,0,0,.06); text-align:center;
        }
        .stat-card .num { font-size:1.8rem; font-weight:700; }
        .stat-card .lbl { font-size:.8rem; color:#6b7280; }
        .btn-action { min-width:110px; }
        @@media(max-width:768px){
            .sidebar{display:none}
            .main-content{margin-right:0}
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="topbar">
    <a href="/" class="brand">рҹ•Ң ЩҶШёШ§Щ… ШҘШҜШ§ШұШ© Ш§Щ„ШӯШ¬</a>
    <div class="d-flex align-items-center gap-3">
        @{
            var isSysAdmin = User.FindFirst("IsSysAdmin")?.Value == "True";
            var fullName   = User.FindFirst("FullName")?.Value ?? User.Identity?.Name;
        }
        @if (isSysAdmin) { <span class="badge bg-warning text-dark">Щ…ШҜЩҠШұ Ш§Щ„ЩҶШёШ§Щ…</span> }
        <span class="small">@fullName</span>
        <form asp-action="Logout" asp-controller="Account" method="post" class="mb-0">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-light">Ш®ШұЩҲШ¬</button>
        </form>
    </div>
</div>

<div class="sidebar">
    <div class="section-title">Ш§Щ„ЩӮШ§ШҰЩ…Ш© Ш§Щ„ШұШҰЩҠШіЩҠШ©</div>
    <a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")">рҹҸ  Ш§Щ„ШұШҰЩҠШіЩҠШ©</a>
    <a href="/Pilgrims" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Pilgrims"?"active":"")">рҹ§‘вҖҚрҹӨқвҖҚрҹ§‘ Ш§Щ„ШӯШ¬Ш§Ш¬</a>
    <a href="/Confirmation" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Confirmation"?"active":"")">вң… Ш§Щ„ШӘШЈЩғЩҠШҜ</a>
    <a href="/Medical" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Medical"?"active":"")">рҹҸҘ Ш§Щ„ШөШӯШ©</a>
    <a href="/FlightDistribution" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="FlightDistribution"?"active":"")">вңҲпёҸ Ш§Щ„ШұШӯЩ„Ш§ШӘ</a>
    <a href="/CentralConfirm" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="CentralConfirm"?"active":"")">рҹҸӣпёҸ Ш§Щ„Щ…ЩҲШ§ЩҒЩӮШ© Ш§Щ„Щ…ШұЩғШІЩҠШ©</a>
    <a href="/Units" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Units"?"active":"")">рҹҸў Ш§Щ„ЩҲШӯШҜШ§ШӘ</a>
    @if (isSysAdmin)
    {
        <div class="section-title">Ш§Щ„ШҘШҜШ§ШұШ©</div>
        <a href="/SeasonRollover" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="SeasonRollover"?"active":"")">рҹ“… ШӘШұШӯЩҠЩ„ Ш§Щ„Щ…ЩҲШіЩ…</a>
    }
</div>

<div class="main-content">
    @RenderBody()
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script>
function showToast(msg, ok=true){
    const t=document.createElement('div');
    t.className=`alert alert-${ok?'success':'danger'} position-fixed`;
    t.style.cssText='bottom:20px;left:20px;z-index:9999;min-width:280px;';
    t.textContent=msg;
    document.body.appendChild(t);
    setTimeout(()=>t.remove(),3500);
}
function postJson(url,data){
    return fetch(url,{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':document.querySelector('[name=__RequestVerificationToken]')?.value??''},body:JSON.stringify(data)});
}
function postForm(url,data){
    const fd=new FormData();
    Object.entries(data).forEach(([k,v])=>fd.append(k,v));
    fd.append('__RequestVerificationToken',document.querySelector('[name=__RequestVerificationToken]')?.value??'');
    return fetch(url,{method:'POST',body:fd});
}
</script>
@Html.AntiForgeryToken()
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
