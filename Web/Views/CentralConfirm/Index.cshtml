@{ ViewData["Title"] = "الموافقة المركزية"; }

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="page-title mb-0">🏛️ الموافقة المركزية</div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" onclick="approveSelected()">اعتماد المحددين</button>
            <button class="btn btn-success btn-sm" onclick="approveAll()">اعتماد الكل</button>
        </div>
    </div>

    <div class="row g-3 mb-4" id="centralStatsRow"></div>

    <table id="centralTable" class="table table-hover table-sm w-100">
        <thead class="table-dark">
            <tr>
                <th><input type="checkbox" id="selectAll"/></th>
                <th>الاسم</th><th>الرقم العسكري</th><th>الرقم المدني</th>
                <th>الجواز</th><th>الوحدة</th><th>النوع</th><th>الحالة</th><th>إجراء</th>
            </tr>
        </thead>
    </table>
</div>

<!-- Return Modal -->
<div class="modal fade" id="returnModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">إرجاع للفرع</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="returnId"/>
                <label class="form-label">سبب الإرجاع</label>
                <textarea id="returnNote" class="form-control" rows="3"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button class="btn btn-warning" onclick="doReturn()">إرجاع</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const confirmMap = {0:'معلق',1:'مؤكد',2:'ملغي',3:'معتمد مركزي',77:'محظور'};
const confirmClr = {0:'secondary',1:'success',2:'danger',3:'primary',77:'dark'};
const typeMap    = {1:'أصيل',2:'احتياطي',3:'إداري'};

let table = $('#centralTable').DataTable({
    ajax:{ url:'/CentralConfirm/ReadConfirmed', dataSrc:'' },
    columns:[
        {data:null, render:(d,t,r)=>`<input type="checkbox" class="row-check" value="${r.pilgrimId}"/>`},
        {data:'fullName'},
        {data:'serviceNumber'},
        {data:'nic'},
        {data:'passport'},
        {data:'unitNameAr'},
        {data:'typeId',      render:v=>typeMap[v]??v},
        {data:'confirmCode', render:v=>`<span class="badge bg-${confirmClr[v]??'secondary'}">${confirmMap[v]??v}</span>`},
        {data:'pilgrimId', render:id=>`<button class="btn btn-sm btn-warning" onclick="openReturn(${id})">إرجاع للفرع</button>`}
    ],
    language:{url:'//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json'},
    pageLength:25
});

$('#selectAll').on('change',function(){ document.querySelectorAll('.row-check').forEach(c=>c.checked=this.checked); });

async function loadStats(){
    const r = await fetch('/CentralConfirm/Stats');
    const d = await r.json();
    document.getElementById('centralStatsRow').innerHTML=`
        <div class="col-6 col-md-2"><div class="stat-card"><div class="num">${d.total}</div><div class="lbl">الكلي</div></div></div>
        <div class="col-6 col-md-2"><div class="stat-card"><div class="num text-success">${d.branchConfirmed}</div><div class="lbl">مؤكد من الفرع</div></div></div>
        <div class="col-6 col-md-2"><div class="stat-card"><div class="num text-warning">${d.pending}</div><div class="lbl">معلق</div></div></div>
        <div class="col-6 col-md-2"><div class="stat-card"><div class="num text-danger">${d.returned}</div><div class="lbl">مرجع</div></div></div>
        <div class="col-6 col-md-2"><div class="stat-card"><div class="num text-danger">${d.passportIssues}</div><div class="lbl">جواز منتهي</div></div></div>`;
}
loadStats();

async function approveAll(){
    if(!confirm('اعتماد جميع السجلات المؤكدة؟')) return;
    const r = await postForm('/CentralConfirm/FinalApproveAll',{});
    const d = await r.json();
    if(r.ok){ showToast(d.message); table.ajax.reload(); loadStats(); }
    else showToast(d,false);
}

async function approveSelected(){
    const ids = [...document.querySelectorAll('.row-check:checked')].map(c=>+c.value);
    if(!ids.length){ showToast('اختر حجاجاً أولاً',false); return; }
    const r = await postJson('/CentralConfirm/FinalApproveSelected',ids);
    const d = await r.json();
    if(r.ok){ showToast(d.message); table.ajax.reload(); loadStats(); }
    else showToast(d,false);
}

function openReturn(id){
    document.getElementById('returnId').value=id;
    document.getElementById('returnNote').value='';
    new bootstrap.Modal(document.getElementById('returnModal')).show();
}

async function doReturn(){
    const id   = document.getElementById('returnId').value;
    const note = document.getElementById('returnNote').value;
    const r = await postForm('/CentralConfirm/ReturnToBranch',{pilgrimId:id, returnNote:note});
    if(r.ok){ showToast('تم الإرجاع'); bootstrap.Modal.getInstance(document.getElementById('returnModal')).hide(); table.ajax.reload(); loadStats(); }
    else showToast(await r.text(),false);
}
</script>
}
