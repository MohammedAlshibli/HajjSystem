@{ ViewData["Title"] = "الحجاج"; }

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="page-title mb-0">🧑‍🤝‍🧑 تسجيل الحجاج</div>
        <div class="d-flex gap-2"><button class="btn btn-outline-primary btn-sm" onclick="openCreate()">+ عبر HRMS</button><a href="/Pilgrims/Manual" class="btn btn-primary btn-sm">+ إضافة يدوي</a></div>
    </div>

    <div class="row g-3 mb-4" id="statsRow"></div>

    <table id="pilgrimsTable" class="table table-hover table-sm w-100">
        <thead class="table-dark">
            <tr>
                <th>#</th><th>الاسم</th><th>الرقم العسكري</th><th>الرقم المدني</th>
                <th>الرتبة</th><th>الوحدة</th><th>النوع</th><th>الحالة</th><th>إجراء</th>
            </tr>
        </thead>
    </table>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">إضافة حاج جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input id="svcNum" class="form-control" placeholder="أدخل الرقم العسكري"/>
                    <button class="btn btn-outline-primary" onclick="fetchHrms()">بحث HRMS</button>
                </div>
                <div id="pilgrimForm"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button class="btn btn-primary" onclick="savePilgrim()">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const typeMap    = {1:'أصيل',2:'احتياطي',3:'إداري'};
const confirmMap = {0:'معلق',51:'مؤكد فرع',99:'ملغي',77:'معتمد مركزي'};
const confirmClr = {0:'secondary',51:'success',99:'danger',77:'primary'};

let table = $('#pilgrimsTable').DataTable({
    ajax:{ url:'/Pilgrims/Read', dataSrc:'' },
    columns:[
        {data:'pilgrimId'},
        {data:'fullName'},
        {data:'serviceNumber'},
        {data:'nic'},
        {data:'rankDesc'},
        {data:'unitNameAr'},
        {data:'typeId',  render:v=>typeMap[v]??v},
        {data:'confirmCode', render:v=>`<span class="badge bg-${confirmClr[v]??'secondary'}">${confirmMap[v]??v}</span>`},
        {data:'pilgrimId', render:id=>`<button class="btn btn-sm btn-danger" onclick="deletePilgrim(${id})">حذف</button>`}
    ],
    language:{url:'//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json'},
    pageLength:25, order:[[0,'desc']]
});

async function loadStats(){
    const r = await fetch('/Units/MyQuota');
    const data = await r.json();
    let total=0, used=0;
    data.forEach(u=>{ total+=(u.quota||0); used+=(u.used||0); });
    document.getElementById('statsRow').innerHTML = `
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num text-primary">${used}</div><div class="lbl">المسجلون</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num text-success">${total}</div><div class="lbl">الحصة الكلية</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num text-warning">${Math.max(0,total-used)}</div><div class="lbl">المتبقي</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card"><div class="num text-info">${data.length}</div><div class="lbl">الوحدات</div></div></div>`;
}
loadStats();

function openCreate(){ new bootstrap.Modal(document.getElementById('createModal')).show(); }

async function fetchHrms(){
    const sn = document.getElementById('svcNum').value.trim();
    if(!sn){ showToast('أدخل الرقم العسكري',false); return; }
    const r = await fetch(`/Pilgrims/FetchFromHrms?serviceNumber=${encodeURIComponent(sn)}`);
    if(!r.ok){ showToast(await r.text(),false); return; }
    document.getElementById('pilgrimForm').innerHTML = await r.text();
}

async function savePilgrim(){
    const form = document.getElementById('pilgrimForm');
    if(!form.innerHTML){ showToast('ابحث عن الموظف أولاً',false); return; }
    const inputs = form.querySelectorAll('input,select');
    const obj = {};
    inputs.forEach(i=>{ if(i.name) obj[i.name]=i.value; });
    const r = await postJson('/Pilgrims/Create', obj);
    const data = await r.json();
    if(r.ok){ showToast(data.message); bootstrap.Modal.getInstance(document.getElementById('createModal')).hide(); table.ajax.reload(); loadStats(); }
    else showToast(data,false);
}

async function deletePilgrim(id){
    if(!confirm('هل تريد حذف هذا الحاج؟')) return;
    const r = await postForm('/Pilgrims/Delete',{pilgrimId:id});
    if(r.ok){ showToast('تم الحذف'); table.ajax.reload(); loadStats(); }
    else showToast(await r.text(),false);
}
</script>
}
